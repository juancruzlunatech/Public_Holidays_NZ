---
import Layout from '../layouts/Layout.astro';
import Card from '../components/starwind/card/Card.astro';
import CardContent from '../components/starwind/card/CardContent.astro';
import CardTitle from '../components/starwind/card/CardTitle.astro';
import { buildHolidayWebPageSchema } from '../lib/seo';

const title = 'NZ Public Holidays 2026 | Complete Calendar New Zealand';
const description = 'Guide to New Zealand public holidays, NZ holidays 2026, Waitangi Day rules, Matariki, mondayisation, and regional holiday differences.';
const pageSchema = buildHolidayWebPageSchema('/guide', title, description);

const articles = [
  {
    title: 'How mondayisation works in NZ',
    href: '/guide/how-mondayisation-works-nz',
    summary: 'A practical explainer of transfer rules when holidays fall on weekends, including worker eligibility and payroll impact.'
  },
  {
    title: "What's open on Waitangi Day?",
    href: '/guide/whats-open-on-waitangi-day',
    summary: 'What services usually close, what can stay open, and how to plan shopping and travel around Waitangi Day.'
  },
  {
    title: 'NZ regional holidays explained',
    href: '/guide/nz-regional-holidays-explained',
    summary: 'Why anniversary days vary by region and how to know which date applies to your location or employment agreement.'
  }
];
---

<Layout title={title} description={description} canonicalPath="/guide" jsonLd={pageSchema}>
  <div class="max-w-5xl mx-auto space-y-8">
    <header class="space-y-4 text-center">
      <h1 class="text-4xl md:text-5xl font-black tracking-tight">New Zealand Holiday Guide</h1>
      <p class="text-muted-foreground max-w-3xl mx-auto leading-relaxed">
        This guide explains how New Zealand public holidays work in real life: national holidays, regional anniversary days,
        mondayisation transfer rules, and common trading-hour restrictions. Use it together with our <a href="/holidays/2026" class="font-semibold text-primary hover:underline underline-offset-4">NZ holidays 2026 calendar</a>
        to plan annual leave, payroll, school breaks, and business operations. We also cover high-interest topics such as Waitangi Day,
        Matariki, and what services typically close on restricted trading days.
      </p>
    </header>

    <section class="grid gap-5 md:grid-cols-3">
      {articles.map((article) => (
        <Card class="border shadow-sm hover:shadow-md transition-shadow">
          <CardContent class="space-y-3 p-5">
            <CardTitle class="text-lg font-black">{article.title}</CardTitle>
            <p class="text-sm text-muted-foreground leading-relaxed">{article.summary}</p>
            <a href={article.href} class="text-sm font-bold text-primary hover:underline underline-offset-4">Read article</a>
          </CardContent>
        </Card>
      ))}
    </section>

    <section class="rounded-3xl border bg-muted/20 p-6 md:p-8 space-y-4">
      <h2 class="text-2xl font-black">Quick Answers</h2>
      <p class="text-sm leading-relaxed text-muted-foreground">
        Waitangi Day and Anzac Day can be mondayised when they land on weekends. Good Friday, Easter Sunday, Christmas Day, and
        Anzac Day morning have stricter shop trading rules. Regional anniversary holidays are not nationwide and depend on region.
      </p>
      <p class="text-sm leading-relaxed">
        For complete dates, see <a href="/holidays/2026" class="font-bold text-primary hover:underline underline-offset-4">Holidays 2026</a> and <a href="/holidays/2027" class="font-bold text-primary hover:underline underline-offset-4">Holidays 2027</a>.
      </p>
    </section>
  </div>
</Layout>
