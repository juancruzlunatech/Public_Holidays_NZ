---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/starwind/badge/Badge.astro';
import Card from '../components/starwind/card/Card.astro';
import Table from '../components/starwind/table/Table.astro';
import TableHeader from '../components/starwind/table/TableHeader.astro';
import TableBody from '../components/starwind/table/TableBody.astro';
import TableRow from '../components/starwind/table/TableRow.astro';
import TableHead from '../components/starwind/table/TableHead.astro';
import TableCell from '../components/starwind/table/TableCell.astro';
import { HOLIDAYS_DATA, formatDateFull, daysUntil, getHolidayIcon } from '../lib/holidays';
import { buildHolidayWebPageSchema, getHolidayPathByName, SITE_URL } from '../lib/seo';

const holidays2026 = [
  ...HOLIDAYS_DATA.national[2026].map(h => ({ ...h, year: 2026 })),
  ...HOLIDAYS_DATA.regional[2026].map(h => ({ ...h, year: 2026 })),
].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const holidays2027 = [
  ...HOLIDAYS_DATA.national[2027].map(h => ({ ...h, year: 2027 })),
  ...HOLIDAYS_DATA.regional[2027].map(h => ({ ...h, year: 2027 })),
].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const title = 'NZ Public Holidays 2026 | Complete Calendar New Zealand';
const description = 'New Zealand public holidays calendar with NZ holidays 2026, Waitangi Day, Matariki, mondayisation rules, and 2027 dates.';

const homeWebsiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'NZ Public Holidays',
  url: `${SITE_URL}/`,
  description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_URL}/guide?query={search_term_string}`,
    'query-input': 'required name=search_term_string'
  }
};

const homePageSchema = buildHolidayWebPageSchema('/', title, description);
---

<Layout title={title} description={description} canonicalPath="/" jsonLd={[homeWebsiteSchema, homePageSchema]}>
  <div class="max-w-5xl mx-auto space-y-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b pb-4">
        <div>
            <h1 class="text-3xl font-black tracking-tight flex items-center gap-3">
                <span class="text-primary">🇳🇿</span> NZ Public Holidays
            </h1>
            <p class="text-muted-foreground text-sm uppercase font-bold tracking-[0.2em] mt-1">Full 2026 & 2027 Calendar</p>
        </div>
        <div class="flex gap-4 text-xs font-bold uppercase tracking-widest bg-muted/30 p-2 px-4 rounded-full border">
            <span class="flex items-center gap-2 text-primary">● National</span>
            <span class="flex items-center gap-2 text-info">● Regional</span>
        </div>
    </div>

    <Card class="overflow-hidden border shadow-lg">
      <div class="overflow-x-auto">
        <Table>
          <TableHeader class="bg-muted/80">
            <TableRow>
              <TableHead class="w-12 text-center text-[10px] uppercase font-black">Type</TableHead>
              <TableHead class="px-6">Holiday Name</TableHead>
              <TableHead>Date</TableHead>
              <TableHead>Day</TableHead>
              <TableHead>Target Area</TableHead>
              <TableHead class="text-right">Status</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {/* 2026 Section */}
            <TableRow class="bg-primary/5 hover:bg-primary/5 select-none">
                <TableCell colspan="6" class="py-2 px-4">
                    <div class="flex items-center gap-3">
                        <span class="text-xl font-black text-primary">2026</span>
                        <div class="h-[1px] flex-1 bg-primary/20"></div>
                        <Badge variant="primary" size="sm" class="font-black">YEAR START</Badge>
                    </div>
                </TableCell>
            </TableRow>
            {holidays2026.map((h) => {
              const dateToCompare = h.mondayised || h.date;
              const days = daysUntil(dateToCompare);
              const isPast = days < 0;
              const isToday = days === 0;

              return (
                <TableRow class={`${isPast ? "opacity-40 grayscale bg-muted/10" : ""} border-l-4 ${h.region ? "border-l-info" : "border-l-primary"}`}>
                  <TableCell class="text-center text-xl p-4">{getHolidayIcon(h.name)}</TableCell>
                  <TableCell class="px-6">
                      {h.region ? (
                        <span class="font-bold text-base">{h.name}</span>
                      ) : (
                        <a href={getHolidayPathByName(h.name) || '#'} class="font-bold text-base hover:text-primary underline-offset-4 hover:underline">
                          {h.name}
                        </a>
                      )}
                  </TableCell>
                  <TableCell class="whitespace-nowrap font-medium text-muted-foreground">{formatDateFull(h.date)}</TableCell>
                  <TableCell class="text-sm font-semibold">{h.day}</TableCell>
                  <TableCell>
                      {h.region ? (
                          <div class="flex items-center gap-2">
                              <div class="w-2 h-2 rounded-full bg-info shadow"></div>
                              <span class="text-xs font-black uppercase text-info tracking-wider">{h.region}</span>
                          </div>
                      ) : (
                          <div class="flex items-center gap-2">
                              <div class="w-2 h-2 rounded-full bg-primary shadow"></div>
                              <span class="text-xs font-black uppercase text-primary tracking-wider font-sans">National</span>
                          </div>
                      )}
                  </TableCell>
                  <TableCell class="text-right whitespace-nowrap px-6">
                    {isToday ? (
                        <Badge variant="error" class="animate-pulse shadow-sm">Today!</Badge>
                    ) : isPast ? (
                        <span class="text-[9px] font-black text-muted-foreground uppercase tracking-widest px-2 py-0.5 border rounded-sm bg-muted/20">Past</span>
                    ) : (
                        <Badge variant="primary" soft class="font-bold border border-primary/10">{days}d away</Badge>
                    )}
                  </TableCell>
                </TableRow>
              );
            })}

            {/* 2027 Separator */}
            <TableRow class="bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-100 dark:hover:bg-neutral-800 border-y-2 border-neutral-300 dark:border-neutral-700 select-none">
                <TableCell colspan="6" class="py-4 px-4">
                    <div class="flex items-center gap-3">
                        <span class="text-2xl font-black text-foreground">2027</span>
                        <div class="h-[2px] flex-1 bg-neutral-300 dark:bg-neutral-700"></div>
                        <Badge variant="secondary" size="lg" class="font-black">NEXT YEAR</Badge>
                    </div>
                </TableCell>
            </TableRow>

            {holidays2027.map((h) => {
              const dateToCompare = h.mondayised || h.date;
              const days = daysUntil(dateToCompare);
              const isPast = days < 0;
              const isToday = days === 0;

              return (
                <TableRow class={`${isPast ? "opacity-30 grayscale" : ""} border-l-4 ${h.region ? "border-l-info" : "border-l-primary"}`}>
                  <TableCell class="text-center text-xl p-4">{getHolidayIcon(h.name)}</TableCell>
                  <TableCell class="px-6">
                      {h.region ? (
                        <span class="font-bold text-base">{h.name}</span>
                      ) : (
                        <a href={getHolidayPathByName(h.name) || '#'} class="font-bold text-base hover:text-primary underline-offset-4 hover:underline">
                          {h.name}
                        </a>
                      )}
                  </TableCell>
                  <TableCell class="whitespace-nowrap font-medium text-muted-foreground">{formatDateFull(h.date)}</TableCell>
                  <TableCell class="text-sm font-semibold">{h.day}</TableCell>
                  <TableCell>
                      {h.region ? (
                          <div class="flex items-center gap-2">
                              <div class="w-2 h-2 rounded-full bg-info shadow"></div>
                              <span class="text-xs font-black uppercase text-info tracking-wider">{h.region}</span>
                          </div>
                      ) : (
                          <div class="flex items-center gap-2">
                              <div class="w-2 h-2 rounded-full bg-primary shadow"></div>
                              <span class="text-xs font-black uppercase text-primary tracking-wider">National</span>
                          </div>
                      )}
                  </TableCell>
                  <TableCell class="text-right whitespace-nowrap px-6">
                    {isToday ? (
                        <Badge variant="error" class="shadow-sm">Today!</Badge>
                    ) : isPast ? (
                        <span class="text-[9px] font-black text-muted-foreground uppercase tracking-widest">Past</span>
                    ) : (
                        <Badge variant="secondary" soft class="font-bold">{days}d away</Badge>
                    )}
                  </TableCell>
                </TableRow>
              );
            })}
          </TableBody>
        </Table>
      </div>
    </Card>

    <div class="p-6 bg-info/5 rounded-3xl border-2 border-info/10 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-white dark:bg-neutral-800 rounded-2xl flex items-center justify-center text-2xl shadow-sm border border-info/20">🔄</div>
            <div>
                <p class="font-bold text-sm">Mondayisation Rules</p>
                <p class="text-xs text-muted-foreground">If a holiday falls on a weekend, it is observed on the next Monday.</p>
            </div>
        </div>
        <a href={`${import.meta.env.BASE_URL}guide`} class="text-sm font-black text-info hover:underline uppercase tracking-tighter">View Detailed Guide ↗</a>
    </div>

    <section class="rounded-3xl border bg-card p-6 md:p-8 shadow-sm space-y-4">
      <h2 class="text-2xl font-black tracking-tight">How Public Holidays Work In New Zealand</h2>
      <p class="text-muted-foreground leading-relaxed">
        New Zealand has a mix of nationwide statutory holidays and regional anniversary days, which means not every public holiday is observed by every worker in the same way. National dates like Waitangi Day, Anzac Day, Matariki, Labour Day, and Christmas Day apply across the country, while anniversary holidays vary by region such as Auckland, Wellington, Canterbury, and Southland. The holiday system also includes transfer rules called mondayisation, so when some holidays fall on a weekend they are officially observed on a following weekday for eligible employees. In practice, this affects payroll, leave calculations, and opening hours for shops and services. Some days such as Good Friday, Easter Sunday, and Christmas Day also come with stricter trading rules for retail businesses. This NZ holidays 2026 calendar helps households, employers, and travelers plan ahead with clear dates, observed shifts, and practical guidance on what is usually open or closed.
      </p>
      <p class="text-sm">
        Need a deeper breakdown? Read the <a href="/guide" class="font-bold text-primary hover:underline underline-offset-4">complete holiday guide</a> and individual pages for each national holiday.
      </p>
    </section>
  </div>
</Layout>
