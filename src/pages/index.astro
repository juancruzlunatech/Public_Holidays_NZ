---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/starwind/badge/Badge.astro';
import Card from '../components/starwind/card/Card.astro';
import Table from '../components/starwind/table/Table.astro';
import TableHeader from '../components/starwind/table/TableHeader.astro';
import TableBody from '../components/starwind/table/TableBody.astro';
import TableRow from '../components/starwind/table/TableRow.astro';
import TableHead from '../components/starwind/table/TableHead.astro';
import TableCell from '../components/starwind/table/TableCell.astro';
import { HOLIDAYS_DATA, formatDateFull, daysUntil, getHolidayIcon } from '../lib/holidays';

// Flatten and Sort All Holidays
const allHolidays = [
  ...HOLIDAYS_DATA.national[2026].map(h => ({ ...h, year: 2026, category: 'National' })),
  ...HOLIDAYS_DATA.regional[2026].map(h => ({ ...h, year: 2026, category: 'Regional' })),
  ...HOLIDAYS_DATA.national[2027].map(h => ({ ...h, year: 2027, category: 'National' })),
  ...HOLIDAYS_DATA.regional[2027].map(h => ({ ...h, year: 2027, category: 'Regional' })),
].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

---

<Layout title="NZ Public Holidays 2026-2027 Full Listing">
  <div class="max-w-5xl mx-auto space-y-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-black tracking-tight flex items-center gap-3">
                <span class="text-primary">🇳🇿</span> NZ Public Holidays 2026-2027
            </h1>
            <p class="text-muted-foreground text-sm">Combined National & Regional anniversary days for the next two years.</p>
        </div>
        <div class="flex gap-2">
            <Badge variant="primary" soft>2026</Badge>
            <Badge variant="secondary" soft>2027</Badge>
        </div>
    </div>

    <Card class="overflow-hidden border shadow-sm">
      <div class="overflow-x-auto">
        <Table>
          <TableHeader class="bg-muted/50">
            <TableRow>
              <TableHead class="w-12 text-center">Icon</TableHead>
              <TableHead>Holiday</TableHead>
              <TableHead>Date</TableHead>
              <TableHead>Day</TableHead>
              <TableHead>Region / Type</TableHead>
              <TableHead class="text-right">Status</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {allHolidays.map((h) => {
              const dateToCompare = h.mondayised || h.date;
              const days = daysUntil(dateToCompare);
              const isPast = days < 0;
              const isToday = days === 0;
              const is2027 = h.year === 2027;

              return (
                <TableRow class={`${isPast ? "opacity-40 grayscale bg-muted/20" : ""} ${is2027 ? "border-l-4 border-l-secondary" : "border-l-4 border-l-primary"}`}>
                  <TableCell class="text-center text-xl">{getHolidayIcon(h.name)}</TableCell>
                  <TableCell>
                      <div class="flex flex-col">
                          <span class="font-bold">{h.name}</span>
                          <span class="text-[10px] text-muted-foreground uppercase font-black">{h.year}</span>
                      </div>
                  </TableCell>
                  <TableCell class="whitespace-nowrap font-medium">{formatDateFull(h.date)}</TableCell>
                  <TableCell class="text-sm">{h.day}</TableCell>
                  <TableCell>
                      {h.region ? (
                          <Badge variant="outline" class="text-[10px] bg-blue-50/50 dark:bg-blue-900/20">{h.region}</Badge>
                      ) : (
                          <Badge variant="primary" soft class="text-[10px] uppercase font-bold tracking-tighter">National</Badge>
                      )}
                  </TableCell>
                  <TableCell class="text-right whitespace-nowrap">
                    {isToday ? (
                        <Badge variant="error" class="animate-pulse">Today!</Badge>
                    ) : isPast ? (
                        <span class="text-[10px] font-bold text-muted-foreground uppercase italic px-3 py-1 bg-muted rounded">Past</span>
                    ) : (
                        <Badge variant="primary" soft>{days} days to go</Badge>
                    )}
                  </TableCell>
                </TableRow>
              );
            })}
          </TableBody>
        </Table>
      </div>
    </Card>

    <div class="p-4 bg-muted/30 rounded-2xl border border-dashed flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
        <p class="text-muted-foreground italic">Note: Regional anniversaries are specific to each province.</p>
        <div class="flex gap-4">
            <div class="flex items-center gap-2"><div class="w-3 h-3 bg-primary rounded-full"></div><span>2026</span></div>
            <div class="flex items-center gap-2"><div class="w-3 h-3 bg-secondary rounded-full"></div><span>2027</span></div>
        </div>
    </div>
  </div>
</Layout>
