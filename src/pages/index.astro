---
import Layout from '../layouts/Layout.astro';
import Button from '../components/starwind/button/Button.astro';
import Card from '../components/starwind/card/Card.astro';
import CardHeader from '../components/starwind/card/CardHeader.astro';
import CardTitle from '../components/starwind/card/CardTitle.astro';
import CardContent from '../components/starwind/card/CardContent.astro';
import CardFooter from '../components/starwind/card/CardFooter.astro';
import Badge from '../components/starwind/badge/Badge.astro';
import Table from '../components/starwind/table/Table.astro';
import TableHeader from '../components/starwind/table/TableHeader.astro';
import TableBody from '../components/starwind/table/TableBody.astro';
import TableRow from '../components/starwind/table/TableRow.astro';
import TableHead from '../components/starwind/table/TableHead.astro';
import TableCell from '../components/starwind/table/TableCell.astro';
import { HOLIDAYS_DATA, getNextHoliday, formatDate, formatDateFull, daysUntil, getHolidayIcon } from '../lib/holidays';

const nextH = getNextHoliday(2026); // Defaulting to 2026 since it's most relevant
const daysAway = nextH ? daysUntil(nextH.effectiveDate) : null;
const holidays2026 = HOLIDAYS_DATA.national[2026];
const regions2026 = HOLIDAYS_DATA.regional[2026];
---

<Layout title="NZ Public Holidays 2026-2027">
  {/* Hero Section */}
  <section class="max-w-2xl mx-auto py-6 text-center space-y-4 mb-8">
    <div class="space-y-1">
      <h1 class="text-2xl md:text-3xl font-black tracking-tight">NZ Public Holidays</h1>
      <p class="text-sm text-muted-foreground max-w-lg mx-auto">Your complete guide to national holidays and regional anniversaries.</p>
    </div>

    {nextH && (
      <Card class="max-w-xs mx-auto border shadow-sm bg-primary/5 hover:border-primary/50 transition-colors">
        <CardContent class="text-center py-3 px-4">
          <div class="flex items-center justify-center gap-3">
              <span class="text-2xl" role="img">{getHolidayIcon(nextH.name)}</span>
              <div class="text-left">
                  <h2 class="text-sm font-bold leading-tight">{nextH.name}</h2>
                  <p class="text-[11px] text-primary font-bold uppercase tracking-wider">{formatDateFull(nextH.effectiveDate)}</p>
              </div>
          </div>
          <div class="mt-2 pt-2 border-t border-primary/10 flex items-center justify-between text-[10px]">
              <Badge variant="primary" soft class="px-1.5 py-0 h-4 text-[9px] uppercase font-bold">{daysAway} days to go</Badge>
              {nextH.mondayised && <span class="text-muted-foreground italic font-medium">Mondayised</span>}
          </div>
        </CardContent>
      </Card>
    )}
  </section>

  {/* Fast Stats */}
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
    <Card class="p-6 text-center border-none bg-muted/30">
        <div class="text-3xl font-black mb-1">11</div>
        <p class="text-xs font-semibold text-muted-foreground uppercase">National Holidays</p>
    </Card>
    <Card class="p-6 text-center border-none bg-muted/30">
        <div class="text-3xl font-black mb-1">12</div>
        <p class="text-xs font-semibold text-muted-foreground uppercase">Regional Anniversaries</p>
    </Card>
    <Card class="p-6 text-center border-none bg-muted/30">
        <div class="text-3xl font-black mb-1">2014</div>
        <p class="text-xs font-semibold text-muted-foreground uppercase">Mondayisation Law</p>
    </Card>
    <Card class="p-6 text-center border-none bg-muted/30">
        <div class="text-3xl font-black mb-1">2022</div>
        <p class="text-xs font-semibold text-muted-foreground uppercase">Matariki Introduced</p>
    </Card>
  </div>

  {/* Year Navigation */}
  <div class="flex flex-wrap gap-2 mb-8 justify-center">
    <Button as="a" href={`${import.meta.env.BASE_URL}/holidays/2026`} variant="primary" size="lg" class="shadow-md">
      View All 2026 Holidays
    </Button>
    <Button as="a" href={`${import.meta.env.BASE_URL}/holidays/2027`} variant="secondary" size="lg" class="shadow-md">
      View All 2027 Holidays
    </Button>
    <Button as="a" href={`${import.meta.env.BASE_URL}/guide`} variant="outline" size="lg">
      Detailed Rules Guide
    </Button>
  </div>

  {/* Summary Listing */}
  <section class="mb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-3xl font-bold flex items-center gap-2">
        <span class="text-2xl">🏛️</span> 
        National Public Holidays 2026
      </h2>
      <Badge size="lg" class="hidden sm:inline-flex">2026 Overview</Badge>
    </div>
    
    <Card class="overflow-hidden border shadow-sm">
      <div class="overflow-x-auto">
        <Table>
          <TableHeader>
            <TableRow>
              <TableHead class="w-12 text-center">#</TableHead>
              <TableHead>Holiday</TableHead>
              <TableHead>Date</TableHead>
              <TableHead>Day</TableHead>
              <TableHead class="text-right">Status</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {holidays2026.map((h, i) => {
              const days = daysUntil(h.mondayised || h.date);
              const isPast = days < 0;
              const isToday = days === 0;
              
              return (
                <TableRow class={isPast ? "opacity-50 grayscale select-none" : ""}>
                  <TableCell class="text-center text-lg">{getHolidayIcon(h.name)}</TableCell>
                  <TableCell class="font-semibold">{h.name}</TableCell>
                  <TableCell>{formatDate(h.date)}</TableCell>
                  <TableCell>{h.day}</TableCell>
                  <TableCell class="text-right">
                    {isPast ? <Badge variant="secondary">Past</Badge> : 
                     isToday ? <Badge variant="error" class="animate-bounce">Today!</Badge> : 
                     <Badge variant="primary" soft>{days} days away</Badge>}
                  </TableCell>
                </TableRow>
              );
            })}
          </TableBody>
        </Table>
      </div>
    </Card>
  </section>

  {/* Information Quick-Links */}
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <Card variant="outline" class="hover:border-primary transition-colors cursor-pointer group">
      <CardHeader>
        <CardTitle class="flex items-center gap-2 group-hover:text-primary transition-colors">
            <span>🔄</span> Mondayisation
        </CardTitle>
      </CardHeader>
      <CardContent class="text-sm text-muted-foreground leading-relaxed">
        Waitangi and Anzac Days move to Monday if on a weekend.
      </CardContent>
    </Card>
    <Card variant="outline" class="hover:border-primary transition-colors cursor-pointer group">
      <CardHeader>
        <CardTitle class="flex items-center gap-2 group-hover:text-primary transition-colors">
            <span>🏪</span> Shop Rules
        </CardTitle>
      </CardHeader>
      <CardContent class="text-sm text-muted-foreground leading-relaxed">
        Understand when shops must close on public holidays.
      </CardContent>
    </Card>
    <Card variant="outline" class="hover:border-primary transition-colors cursor-pointer group">
      <CardHeader>
        <CardTitle class="flex items-center gap-2 group-hover:text-primary transition-colors">
            <span>📍</span> Regional Days
        </CardTitle>
      </CardHeader>
      <CardContent class="text-sm text-muted-foreground leading-relaxed">
        Your specific day off depends on which province you work in.
      </CardContent>
    </Card>
  </div>
</Layout>
