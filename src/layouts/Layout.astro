---
import '../styles/starwind.css';
import Button from '../components/starwind/button/Button.astro';
import { buildNationalHolidayEventSchema, SITE_URL } from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = 'New Zealand public holidays calendar with NZ holidays 2026, Waitangi Day, Matariki, and official mondayisation rules.',
  canonicalPath,
  ogImage = '/favicon-192x192.png',
  jsonLd
} = Astro.props as Props;

const currentYear = new Date().getFullYear();
const pathname = canonicalPath || Astro.url.pathname;
const canonicalUrl = new URL(pathname, SITE_URL).toString();
const ogImageUrl = new URL(ogImage, SITE_URL).toString();
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION || 'REPLACE_WITH_GOOGLE_SITE_VERIFICATION_TOKEN';

const structuredData: Array<Record<string, unknown>> = [
  ...buildNationalHolidayEventSchema(2026),
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content={googleVerification} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NZ Public Holidays" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    {structuredData.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans">
    <header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
      <div class="container mx-auto flex h-16 items-center justify-between px-4">
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 font-bold text-xl">
          <span class="text-2xl">🇳🇿</span>
          <span>NZ Public <span class="text-primary">Holidays</span></span>
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
          <a href={import.meta.env.BASE_URL} class="transition-colors hover:text-primary">Home</a>
          <a href={`${import.meta.env.BASE_URL}holidays/2026`} class="transition-colors hover:text-primary">2026</a>
          <a href={`${import.meta.env.BASE_URL}holidays/2027`} class="transition-colors hover:text-primary">2027</a>
          <a href={`${import.meta.env.BASE_URL}guide`} class="transition-colors hover:text-primary">Guide</a>
        </nav>
        <div class="flex items-center gap-4">
          <Button variant="outline" size="sm" class="hidden sm:flex" id="theme-toggle">
            🌙 Mode
          </Button>
          <button class="md:hidden p-2" aria-label="Toggle Menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
          </button>
        </div>
      </div>
    </header>

    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="border-t bg-muted/50">
      <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <div>
            <h3 class="font-bold text-lg mb-4">🇳🇿 NZ Public Holidays</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">
              Your complete guide to public holidays in Aotearoa New Zealand. Blazing fast informational site updated for 2026-2027.
            </p>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-4">Quick Links</h3>
            <ul class="space-y-2 text-sm">
              <li><a href={`${import.meta.env.BASE_URL}holidays/2026`} class="text-muted-foreground hover:text-primary transition-colors">Holidays 2026</a></li>
              <li><a href={`${import.meta.env.BASE_URL}holidays/2027`} class="text-muted-foreground hover:text-primary transition-colors">Holidays 2027</a></li>
              <li><a href={`${import.meta.env.BASE_URL}guide`} class="text-muted-foreground hover:text-primary transition-colors">Holiday Guide</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-4">Official Sources</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="https://www.employment.govt.nz" target="_blank" class="text-muted-foreground hover:text-primary transition-colors">Employment NZ ↗</a></li>
              <li><a href="https://www.govt.nz" target="_blank" class="text-muted-foreground hover:text-primary transition-colors">NZ Government ↗</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t text-center text-sm text-muted-foreground flex flex-col md:flex-row items-center justify-between gap-4">
          <p>© {currentYear} NZ Public Holidays. Built with Astro & StarWind UI.</p>
          <div class="flex gap-6">
            <a href={`${import.meta.env.BASE_URL}privacy`} class="hover:text-primary transition-colors underline-offset-4 hover:underline">Privacy Policy</a>
            <a href={`${import.meta.env.BASE_URL}terms`} class="hover:text-primary transition-colors underline-offset-4 hover:underline">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      const themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          document.documentElement.classList.toggle('dark');
          const isDark = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          themeToggle.innerHTML = isDark ? '☀️ Light' : '🌙 Dark';
        });

        const storedTheme = localStorage.getItem('theme');
        if (storedTheme === 'dark' || (!storedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
          themeToggle.innerHTML = '☀️ Light';
        } else {
          themeToggle.innerHTML = '🌙 Dark';
        }
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --container-max-width: 1280px;
  }
</style>
