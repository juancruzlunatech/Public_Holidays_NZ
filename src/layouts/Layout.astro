---
import '../styles/starwind.css';
import Button from '../components/starwind/button/Button.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Complete guide to New Zealand public holidays for 2026 and 2027." } = Astro.params as unknown as Props || Astro.props;
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | PublicHolidaysNZ</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "NZ Public Holidays",
        "url": "https://nzpublicholidays.com/",
        "description": "The complete guide to public holidays in New Zealand for 2026 and 2027.",
        "publisher": {
          "@type": "Organization",
          "name": "NZ Public Holidays"
        }
      }
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans">
    <header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
      <div class="container mx-auto flex h-16 items-center justify-between px-4">
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 font-bold text-xl">
          <span class="text-2xl">🇳🇿</span>
          <span>NZ Public <span class="text-primary">Holidays</span></span>
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
          <a href={import.meta.env.BASE_URL} class="transition-colors hover:text-primary">Home</a>
          <a href={`${import.meta.env.BASE_URL}holidays/2026`} class="transition-colors hover:text-primary">2026</a>
          <a href={`${import.meta.env.BASE_URL}holidays/2027`} class="transition-colors hover:text-primary">2027</a>
          <a href={`${import.meta.env.BASE_URL}guide`} class="transition-colors hover:text-primary">Guide</a>
        </nav>
        <div class="flex items-center gap-4">
          <Button variant="outline" size="sm" class="hidden sm:flex" id="theme-toggle">
            🌙 Mode
          </Button>
          <button class="md:hidden p-2" aria-label="Toggle Menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></button>
        </div>
      </div>
    </header>

    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="border-t bg-muted/50">
      <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <div>
            <h3 class="font-bold text-lg mb-4">🇳🇿 NZ Public Holidays</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">
              Your complete guide to public holidays in Aotearoa New Zealand. Blazing fast informational site updated for 2026–2027.
            </p>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-4">Quick Links</h3>
            <ul class="space-y-2 text-sm">
              <li><a href={`${import.meta.env.BASE_URL}holidays/2026`} class="text-muted-foreground hover:text-primary transition-colors">Holidays 2026</a></li>
              <li><a href={`${import.meta.env.BASE_URL}holidays/2027`} class="text-muted-foreground hover:text-primary transition-colors">Holidays 2027</a></li>
              <li><a href={`${import.meta.env.BASE_URL}guide`} class="text-muted-foreground hover:text-primary transition-colors">Holiday Guide</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-4">Official Sources</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="https://www.employment.govt.nz" target="_blank" class="text-muted-foreground hover:text-primary transition-colors">Employment NZ ↗</a></li>
              <li><a href="https://www.govt.nz" target="_blank" class="text-muted-foreground hover:text-primary transition-colors">NZ Government ↗</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t text-center text-sm text-muted-foreground">
          <p>© {currentYear} NZ Public Holidays. Built with Astro & StarWind UI.</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      const themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          document.documentElement.classList.toggle('dark');
          const isDark = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          themeToggle.innerHTML = isDark ? '☀️ Light' : '🌙 Dark';
        });

        const storedTheme = localStorage.getItem('theme');
        if (storedTheme === 'dark' || (!storedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
          themeToggle.innerHTML = '☀️ Light';
        } else {
          themeToggle.innerHTML = '🌙 Dark';
        }
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --container-max-width: 1280px;
  }
</style>
